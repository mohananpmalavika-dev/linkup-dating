{
  "name": "datinghub-api",
  "version": "1.0.0",
  "description": "Backend API for DatingHub App",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "init:db": "node scripts/init-ip-blocklist.js",
    "sync:db": "node scripts/syncDatabase.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "db:create": "npx sequelize-cli db:create",
    "db:drop": "npx sequelize-cli db:drop",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all"
  },
  "keywords": [
    "dating",
    "api",
    "express",
    "websocket"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.3.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-cors": "^0.0.1",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "firebase-admin": "^12.0.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.9.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.1",
    "pg": "^8.8.0",
    "pg-hstore": "^2.3.4",
    "razorpay": "^2.9.6",
    "sequelize": "^6.37.3",
    "sequelize-cli": "^6.6.2",
    "socket.io": "^4.5.4",
    "twilio": "^6.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
